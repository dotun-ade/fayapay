# =============================================================================
# Fayapay — environment variables
# Copy to .env and fill in. Do NOT commit .env.
# Secrets are pulled from Doppler in staging/prod; this is the local fallback.
# =============================================================================

# ---- Core ----
NODE_ENV=development
LOG_LEVEL=debug
APP_BASE_URL=http://localhost:4000
DASHBOARD_BASE_URL=http://localhost:3000
INTERNAL_API_KEY=dev-internal-please-rotate

# ---- Database ----
DATABASE_URL=postgresql://fayapay:fayapay@localhost:5432/fayapay?schema=public
DIRECT_DATABASE_URL=postgresql://fayapay:fayapay@localhost:5432/fayapay?schema=public
DATABASE_POOL_SIZE=10

# ---- Redis / Queues ----
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=fayapay

# ---- Auth ----
JWT_SECRET=change-me-in-prod-please-32-bytes-min
JWT_ISSUER=fayapay.app
SESSION_TTL_SECONDS=3600
REFRESH_TTL_SECONDS=2592000

# ---- Observability ----
SENTRY_DSN=
DATADOG_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=

# =============================================================================
# Card Issuing
# =============================================================================

# Sudo Africa (NGN, KES, GHS virtual + physical)
SUDO_BASE_URL=https://api.sandbox.sudo.cards
SUDO_API_KEY=
SUDO_WEBHOOK_SECRET=
SUDO_DEFAULT_FUNDING_SOURCE_ID=

# =============================================================================
# Payments / Collections / Transfers
# =============================================================================

# Paystack (NGN collections + transfers, GHS, ZAR partial)
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Flutterwave (pan-Africa collections + payouts)
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# =============================================================================
# USD / EUR / GBP rails + FX
# =============================================================================

# Wise (multi-currency receive + send)
WISE_BASE_URL=https://api.sandbox.transferwise.tech
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_WEBHOOK_PUBLIC_KEY_PATH=./secrets/wise_webhook_pub.pem

# Currencycloud (FX + GBP/EUR collection accounts)
CURRENCYCLOUD_BASE_URL=https://devapi.currencycloud.com/v2
CURRENCYCLOUD_LOGIN_ID=
CURRENCYCLOUD_API_KEY=
CURRENCYCLOUD_WEBHOOK_SECRET=

# Modulr (GBP Faster Payments + SEPA)
MODULR_BASE_URL=https://api-sandbox.modulrfinance.com/api-sandbox
MODULR_API_KEY=
MODULR_HMAC_SECRET=
MODULR_CUSTOMER_ID=

# =============================================================================
# KYC / KYB / Identity
# =============================================================================

# Dojah (NG BVN / NIN / CAC). Sole identity vendor.
DOJAH_BASE_URL=https://sandbox.dojah.io
DOJAH_APP_ID=
DOJAH_SECRET_KEY=
DOJAH_WEBHOOK_SECRET=

# =============================================================================
# Feature flags
# =============================================================================
FEATURE_SUDO_PRIMARY_NG=true
FEATURE_FX_PROVIDER=wise
