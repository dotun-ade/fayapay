{
  "name": "fayapay",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build && pnpm -r --filter=./apps/* build",
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "dev:api": "pnpm --filter @fayapay/api dev",
    "dev:web": "pnpm --filter @fayapay/web dev",
    "dev:worker": "pnpm --filter @fayapay/worker dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @fayapay/db generate",
    "db:migrate": "pnpm --filter @fayapay/db migrate",
    "db:seed": "pnpm --filter @fayapay/db seed",
    "db:studio": "pnpm --filter @fayapay/db studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
